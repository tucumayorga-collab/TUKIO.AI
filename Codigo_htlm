<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TUKIO.AI - Interfaz Neurosensorial</title>
    <style>
        body {
            background-color: #1a1a1a;
            color: #ffffff;
            font-family: 'Times New Roman', Times, serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .container {
            width: 100%;
            max-width: 800px;
            background-color: #262626;
            border: 1px solid #404040;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }
        h1 {
            font-size: 24px;
            text-align: center;
            letter-spacing: 2px;
            border-bottom: 1px solid #404040;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }
        .terminal {
            background-color: #0d0d0d;
            border: 1px solid #333333;
            padding: 15px;
            font-family: monospace;
            font-size: 14px;
            line-height: 1.5;
            color: #a6a6a6;
            overflow-y: auto;
            max-height: 300px;
            margin-bottom: 20px;
        }
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        label {
            font-size: 14px;
            letter-spacing: 1px;
            color: #cccccc;
        }
        textarea {
            width: 100%;
            height: 100px;
            background-color: #121212;
            border: 1px solid #404040;
            color: #ffffff;
            padding: 10px;
            font-family: monospace;
            resize: none;
            box-sizing: border-box;
        }
        button {
            background-color: #ffffff;
            color: #000000;
            border: none;
            padding: 12px 20px;
            font-family: 'Times New Roman', Times, serif;
            font-size: 16px;
            cursor: pointer;
            font-weight: bold;
            letter-spacing: 1px;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #cccccc;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>TUKIO.AI // INTERFAZ DE CONTROL</h1>
    
    <div class="terminal" id="outputTerminal">
        [SISTEMA] -> MONITOR UDM50 INICIADO<br>
        [SISTEMA] -> COHERENCIA ABSOLUTA VERIFICADA
    </div>

    <div class="input-group">
        <label for="textInput">INGRESO DE TEXTO (PERIFERIA):</label>
        <textarea id="textInput" placeholder="Inserte flujo de texto para análisis semántico..."></textarea>
        <button onclick="procesarTexto()">EJECUTAR VALIDACIÓN</button>
    </div>
</div>

<script>
    function procesarTexto() {
        const input = document.getElementById('textInput').value;
        const terminal = document.getElementById('outputTerminal');
        
        if (!input.trim()) {
            terminal.innerHTML += `<br>[ALERTA] -> Entrada vacía detectada.`;
            return;
        }

        // Simulación básica de la respuesta del sistema en base al script de Python
        terminal.innerHTML += `<br><br>[SISTEMA] -> Analizando entrada de red...`;
        terminal.innerHTML += `<br>[SISTEMA] -> Evaluando contexto de red y canal sensorial por IA...`;
        terminal.innerHTML += `<br>[RESULTADO] -> Modo de salida purificada generado con éxito.`;
        
        // Limpiar el input
        document.getElementById('textInput').value = '';
        
        // Scroll automático al final de la terminal
        terminal.scrollTop = terminal.scrollHeight;
    }
</script>

</body>
</html>
